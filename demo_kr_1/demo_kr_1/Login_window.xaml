<Window x:Class="demo_kr_1.Login_window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo_kr_1"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800"
        Icon="/Resourses/Images/Icon.ico"
        FontFamily="Times New Roman">

   
    <Window.Resources>

        <Style TargetType="Label">
            <Setter Property="FontSize" Value="25"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0 10"/>

        </Style>
        <Style TargetType="Button">

            <Setter Property="Background" Value="#00fa9a"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0 10"/>

        </Style>
       
    </Window.Resources>
    
    <Grid>
        <StackPanel Orientation="Vertical"
                    Width="300"
                    VerticalAlignment="Center">


            <TextBlock Text="Авторизайия"
                       FontSize="30"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       Margin="0 10 0 50"
                       Foreground="Black"/>

        <Label Content="Login"/>
        <TextBlock FontSize="35"
                   Margin="20 0"/>
        
        <Label Content="Password"/>
        <PasswordBox FontSize="35"
                     Margin="20 0"/>

            <Button Content="Войти"/>
            <Button Content="Войти как гость"/>

        </StackPanel>
        
        
    </Grid>
</Window>
